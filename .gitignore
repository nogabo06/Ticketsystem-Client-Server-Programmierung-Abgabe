# ─────────────────────────────────────────────────────────────
# Root .gitignore for the whole repository.
# A .gitignore only applies to its own directory subtree, so IDE/OS
# rules must live here at the root to take effect everywhere.
# ─────────────────────────────────────────────────────────────

# --- Node / Frontend (Vite) ---
node_modules/
dist/
dist-ssr/
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Java / Maven (Backend) ---
target/
out/
build/
*.class

# --- Lokale Secrets / DB-Konfiguration (NICHT einchecken!) ---
db.properties
.env

# --- IntelliJ IDEA ---
.idea/
*.iml
*.iws
*.ipr

# --- VS Code ---
.vscode/
!.vscode/extensions.json

# --- Eclipse ---
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# --- Operating system junk ---
.DS_Store
Thumbs.db

# --- Lokale Entwickler-Notizen (nicht Teil des Projekts) ---
CLAUDE.md
